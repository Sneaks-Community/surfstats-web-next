# Database Configuration
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=surfstats
MYSQL_PASSWORD=surfstats_password
MYSQL_DATABASE=cksurf

# Player Analytics Database Configuration (optional - for player time tracking). Review documentation for required fork.
ANALYTICS_MYSQL_HOST=localhost
ANALYTICS_MYSQL_PORT=3306
ANALYTICS_MYSQL_USER=surfstats
ANALYTICS_MYSQL_PASSWORD=surfstats_password
ANALYTICS_MYSQL_DATABASE=player_analytics_surf

# Steam API Configuration
# Get your key from: https://steamcommunity.com/dev/apikey
STEAM_API_KEY=your_steam_api_key_here

# Server Configuration (JSON Array)
SERVERS_JSON=[{"name":"Main Server","ip":"127.0.0.1","port":27015}]

# Optional: Map Images Base URL
MAP_IMAGES_URL=https://image.gametracker.com/images/maps/160x120/csgo/

# Optional: Main Site Configuration
NEXT_PUBLIC_MAIN_SITE_URL=https://github.com/Sneaks-Community
NEXT_PUBLIC_MAIN_SITE_NAME=Main Site

# Optional: Footer Links Configuration
NEXT_PUBLIC_FOOTER_LINK_URL=https://discord.com/invite/your_invite_code
NEXT_PUBLIC_FOOTER_LINK_TEXT=Discord

# Optional: Logging Configuration
LOG_LEVEL=warn
